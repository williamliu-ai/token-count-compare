# token-count-compare API key template
#
# Usage:
#   cp .env.example .env
#   editor .env
#
# Keep .env local only. Do not commit real API keys.

# Required for claude-* benchmark + verification runs.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Required for gpt-* benchmark + verification runs.
OPENAI_API_KEY=sk-REPLACE_ME

# The models to compare live in the MODELS list in compare_tokens.py (provider is
# inferred from each id). The only model setting here is the baseline that every
# other model is measured against; it must be one of MODELS.
BASELINE_MODEL=gpt-5.5

# Optional: uncomment only if you use a compatible proxy or custom endpoint.
# OPENAI_BASE_URL=
# ANTHROPIC_BASE_URL=
