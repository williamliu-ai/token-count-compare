      },
      "pricing_usd_per_million": {"input": 15.0, "output": 75.0},
      "tokenizer_notes": "count_tokens is documented as an estimate; may differ slightly from create-message usage"
    },
    {
      "id": "gpt-5.5",
      "vendor": "openai",
      "context_window_tokens": 400000,
      "endpoints": {
        "responses": "https://api.openai.com/v1/responses",
        "input_tokens_count": "https://api.openai.com/v1/responses/input_tokens"
      },
      "pricing_usd_per_million": {"input": 12.5, "output": 60.0},
      "tokenizer_notes": "input_tokens.count returns the exact input count for the Responses API"
    }
  ],
