+def classify_size_tier(tokens: int | None) -> str:
+    if tokens is None:
+        return "unknown"
+    if tokens < SIZE_TIER_PROBE_MAX_TOKENS:
+        return "probe"
+    if tokens >= SIZE_TIER_SCALING_MIN_TOKENS:
+        return "scaling"
+    return "signal"
